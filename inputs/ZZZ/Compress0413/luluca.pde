// ----------------------------------------------------------------------
// Sketch
// ----------------------------------------------------------------------
void setup() {
  size(596, 842);
  smooth(8);
  noLoop();
}

void draw() {
  background(255);
  strokeCap(ROUND);
  strokeJoin(ROUND);

  // 1) curves -- stroked, no fill
  noFill();
  stroke(0);
  strokeWeight(1.5);
  for (float[] path : curvePaths) {
    drawBezierPath(path);
  }

  // 2) filled shapes -- fill black, no stroke (matches SVG defaults)
  fill(0);
  noStroke();
  for (float[] path : filledPaths) {
    drawBezierPath(path);
  }

  // 3) ellipses
  ellipseMode(CENTER);
  strokeWeight(1.5);
  for (float[] e : ellipses) {
    if (e[4] > 0.5) {
      fill(0);
      noStroke();
    } else {
      noFill();
      stroke(0);
    }
    ellipse(e[0], e[1], e[2], e[3]);
  }
}

// Draw a flat Bezier path: [sx,sy, c1x,c1y,c2x,c2y,ex,ey, ...]
void drawBezierPath(float[] p) {
  beginShape();
  vertex(p[0], p[1]);
  for (int i = 2; i + 5 < p.length; i += 6) {
    bezierVertex(p[i], p[i + 1], p[i + 2], p[i + 3], p[i + 4], p[i + 5]);
  }
  endShape();
}
